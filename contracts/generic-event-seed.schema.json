{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miroworld.local/contracts/generic-event-seed.schema.json",
  "title": "GenericEventSeed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "core_question",
    "primary_topic",
    "secondary_topics",
    "coverage_requirements",
    "coverage_report",
    "background_summary",
    "why_this_matters",
    "time_scope",
    "geographic_scope",
    "domain_tags",
    "actors",
    "systems",
    "constraints",
    "environments",
    "interaction_mechanisms",
    "timeline",
    "uncertainties",
    "branch_hypotheses"
  ],
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "core_question": {
      "type": "string",
      "minLength": 1
    },
    "primary_topic": {
      "type": "string",
      "enum": [
        "technology_risk",
        "policy_governance",
        "geopolitics_security",
        "industry_competition",
        "ecology_resources",
        "social_public_system",
        "general_complex_event"
      ]
    },
    "secondary_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverage_requirements": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "coverage_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "counts",
        "missing_sections",
        "passes"
      ],
      "properties": {
        "required": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "missing_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "passes": {
          "type": "boolean"
        }
      }
    },
    "background_summary": {
      "type": "string"
    },
    "why_this_matters": {
      "type": "string"
    },
    "time_scope": {
      "type": "string"
    },
    "geographic_scope": {
      "type": "string"
    },
    "domain_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "motivation",
          "leverage",
          "stance"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string" },
          "motivation": { "type": "string" },
          "leverage": { "type": "string" },
          "stance": { "type": "string" }
        }
      }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "description",
          "importance"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string" },
          "description": { "type": "string" },
          "importance": { "type": "string" }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "description",
          "pressure_on"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string" },
          "description": { "type": "string" },
          "pressure_on": { "type": "string" }
        }
      }
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "description",
          "signal"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string" },
          "description": { "type": "string" },
          "signal": { "type": "string" }
        }
      }
    },
    "interaction_mechanisms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mechanism",
          "description",
          "participants",
          "impact"
        ],
        "properties": {
          "mechanism": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "participants": {
            "type": "array",
            "items": { "type": "string" }
          },
          "impact": { "type": "string" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "time",
          "event",
          "significance"
        ],
        "properties": {
          "time": { "type": "string", "minLength": 1 },
          "event": { "type": "string", "minLength": 1 },
          "significance": { "type": "string" }
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "branch_hypotheses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
