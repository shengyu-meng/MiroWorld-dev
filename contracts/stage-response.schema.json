{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miroworld.local/contracts/stage-response.schema.json",
  "title": "StageResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_context", "surface_defaults", "observatory", "intervention", "cost_lens", "ripple", "archive", "process_trace", "version"],
  "properties": {
    "project_context": {
      "type": "object",
      "required": ["project_id", "headline", "summary", "status", "source_label", "display_language"],
      "additionalProperties": false,
      "properties": {
        "project_id": { "type": "string" },
        "headline": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" },
        "source_label": { "type": "string" },
        "display_language": { "type": "string", "enum": ["zh", "en"] }
      }
    },
    "surface_defaults": {
      "type": "object",
      "required": [
        "selected_event_id",
        "selected_branch_id",
        "active_surface",
        "revealed_event_count",
        "progress_saved_at"
      ],
      "additionalProperties": false,
      "properties": {
        "selected_event_id": { "type": "string" },
        "selected_branch_id": { "type": "string" },
        "active_surface": {
          "type": "string",
          "enum": ["observatory", "intervention", "cost", "ripple", "archive"]
        },
        "revealed_event_count": { "type": "integer", "minimum": 1 },
        "progress_saved_at": { "type": "string" }
      }
    },
    "observatory": { "type": "object" },
    "intervention": { "type": "object" },
    "cost_lens": { "type": "object" },
    "ripple": { "type": "object" },
    "archive": { "type": "object" },
    "process_trace": {
      "type": "object",
      "required": ["run_id", "generated_at", "artifact_root", "storage_mode", "steps"],
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string" },
        "generated_at": { "type": "string" },
        "artifact_root": { "type": "string" },
        "storage_mode": { "type": "string", "const": "local_gitignored_runtime" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "event_id",
              "event_title",
              "branch_id",
              "branch_label",
              "status",
              "artifact_path",
              "artifact_kind",
              "summary",
              "layer_results",
              "intervention_window",
              "artifact_preview"
            ],
            "additionalProperties": false,
            "properties": {
              "step_id": { "type": "string" },
              "event_id": { "type": "string" },
              "event_title": { "type": "string" },
              "branch_id": { "type": "string" },
              "branch_label": { "type": "string" },
              "status": { "type": "string" },
              "artifact_path": { "type": "string" },
              "artifact_kind": { "type": "string" },
              "summary": { "type": "string" },
              "layer_results": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["layer", "title", "inputs", "outputs", "confidence_note"],
                  "additionalProperties": false,
                  "properties": {
                    "layer": { "type": "string", "enum": ["FACT", "INFERENCE", "VALUE", "ACTION"] },
                    "title": { "type": "string" },
                    "inputs": { "type": "array", "items": { "type": "string" } },
                    "outputs": { "type": "array", "items": { "type": "string" } },
                    "confidence_note": { "type": "string" }
                  }
                }
              },
              "intervention_window": {
                "type": "object",
                "required": ["is_open", "urgency", "recommended_input_type", "effect_scope", "target_event_id", "target_branch_id", "prompt", "reason"],
                "additionalProperties": false,
                "properties": {
                  "is_open": { "type": "boolean" },
                  "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
                  "recommended_input_type": { "type": "string", "enum": ["observation", "correction", "intervention", "preference"] },
                  "effect_scope": { "type": "string", "enum": ["evidence", "world_state", "ranking"] },
                  "target_event_id": { "type": "string" },
                  "target_branch_id": { "type": "string" },
                  "prompt": { "type": "string" },
                  "reason": { "type": "string" }
                }
              },
              "artifact_preview": {
                "type": "object",
                "required": ["event_id", "primary_confidence", "counter_signal_count", "cost_mass"],
                "additionalProperties": false,
                "properties": {
                  "event_id": { "type": "string" },
                  "primary_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "counter_signal_count": { "type": "integer", "minimum": 0 },
                  "cost_mass": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        }
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  }
}
