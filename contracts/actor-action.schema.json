{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miroworld.local/contracts/actor-action.schema.json",
  "title": "ActorActionSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_type",
    "label",
    "description",
    "target_kinds",
    "effect_axes",
    "prerequisites",
    "resource_cost",
    "escalation_risk",
    "reversibility",
    "default_confidence"
  ],
  "properties": {
    "action_type": {
      "type": "string",
      "enum": [
        "deploy",
        "regulate",
        "sanction",
        "cooperate",
        "attack",
        "withdraw",
        "negotiate",
        "monitor",
        "harden",
        "audit",
        "reallocate",
        "share"
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "target_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effect_axes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resource_cost": {
      "type": "string",
      "minLength": 1
    },
    "escalation_risk": {
      "type": "string",
      "minLength": 1
    },
    "reversibility": {
      "type": "string",
      "minLength": 1
    },
    "default_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
