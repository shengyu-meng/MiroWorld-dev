{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miroworld.local/contracts/share-artifact.schema.json",
  "title": "ShareArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "subtitle",
    "summary",
    "disclaimer",
    "share_text",
    "tags"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "disclaimer": { "type": "string", "minLength": 1 },
    "share_text": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "short_excerpt": { "type": "string" },
    "poster_caption": { "type": "string" },
    "curator_note": { "type": "string" },
    "wall_label": { "type": "string" },
    "archive_summary": { "type": "string" }
  }
}
