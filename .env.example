# Root environment example for local development.
# Copy to `.env` and fill in local-only secrets.

# API runtime
HOST=127.0.0.1
PORT=8000
DATA_DIR=./data/runtime
FRONTEND_ORIGIN=http://127.0.0.1:4173
VITE_API_BASE_URL=http://127.0.0.1:8000

# LLM runtime (server-side only)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL_NAME=MiniMax-M2.7-highspeed
LLM_REQUEST_TIMEOUT=180
# Prompt starts use MiniMax reasoning when a local key is configured.
# Without a key, the API safely falls back to deterministic compilation.
LLM_SEED_COMPILER_ENABLED=true
